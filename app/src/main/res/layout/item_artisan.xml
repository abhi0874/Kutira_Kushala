<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="@color/primary_gold">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgArtisanAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:padding="12dp"
            android:background="@color/bg_dark"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:tint="@color/primary_gold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtArtisanName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artisan Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_high_emphasis"/>
            <TextView
                android:id="@+id/txtArtisanSpecialty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specialization"
                android:textColor="@color/primary_gold"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/txtArtisanLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location Cluster"
                android:textColor="@color/text_medium_emphasis"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallArtisan"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@android:drawable/ic_menu_call"
            app:iconTint="@color/primary_gold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>